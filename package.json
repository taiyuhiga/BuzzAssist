{
  "name": "buzzassist-canvas-mcp",
  "version": "0.1.19",
  "description": "BuzzAssist project-local Excalidraw canvas plugin with MCP-backed tools for AI coding agents.",
  "homepage": "https://github.com/sam-mountainman/BuzzAssist",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sam-mountainman/BuzzAssist.git"
  },
  "type": "module",
  "bin": {
    "buzzassist-canvas-mcp": "mcp/server.mjs",
    "buzzassist-canvas": "scripts/serve-canvas.mjs",
    "excalidraw-canvas-mcp": "mcp/server.mjs",
    "excalidraw-canvas": "scripts/serve-canvas.mjs"
  },
  "files": [
    "assets/",
    ".agents/mcp_config.json",
    ".agents/plugins/marketplace.json",
    ".antigravity-plugin/plugin.json",
    ".codex-plugin/plugin.json",
    ".claude-plugin/plugin.json",
    ".claude-plugin/marketplace.json",
    ".cursor/mcp.json",
    ".cursor/rules/buzzassist.mdc",
    ".mcp.json",
    "dist/",
    "dist-widget/",
    "lib/*.mjs",
    "mcp/server.mjs",
    "scripts/*.mjs",
    "scripts/*.sh",
    "skills/",
    "./AGENTS.md",
    "./CLAUDE.md",
    "./GEMINI.md",
    "./README.md",
    "./SETUP.md",
    "package-lock.json",
    "vite.config.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:widget": "node scripts/build-widget.mjs",
    "serve": "node scripts/serve-canvas.mjs",
    "setup:agents": "node scripts/setup-agents.mjs",
    "update:check": "node scripts/update-current.mjs --check-only",
    "update:now": "node scripts/update-current.mjs",
    "update:auto": "node scripts/auto-update.mjs install",
    "update:status": "node scripts/auto-update.mjs status",
    "update:disable": "node scripts/auto-update.mjs uninstall",
    "release:verify": "node scripts/verify-release-version.mjs",
    "mcp": "node mcp/server.mjs",
    "preview": "node scripts/serve-canvas.mjs",
    "remote:start": "node scripts/remote-canvas-relay.mjs start",
    "remote:status": "node scripts/remote-canvas-relay.mjs status",
    "remote:stop": "node scripts/remote-canvas-relay.mjs stop",
    "tunnel:start": "node scripts/canvas-tunnel.mjs start",
    "tunnel:status": "node scripts/canvas-tunnel.mjs status",
    "tunnel:stop": "node scripts/canvas-tunnel.mjs stop",
    "test": "node scripts/run-tests.mjs",
    "test:setup": "node scripts/test-setup-distribution.mjs",
    "test:project-routing": "node scripts/test-active-project-routing.mjs",
    "prepack": "npm run build",
    "postinstall": "node scripts/patch-excalidraw.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fractional-indexing": "^3.2.0",
    "kuromoji": "^0.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0",
    "zod": "^4.4.3"
  }
}
